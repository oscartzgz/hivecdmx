#!/bin/bash
# bin/setup-ssl — Obtiene el certificado Let's Encrypt por primera vez.
# Uso: bin/setup-ssl tu@email.com
# Prerrequisito: puerto 80 accesible desde internet (port-forward en el router).
set -e

DOMAIN="kz360c1.glddns.com"
EMAIL="${1:?Uso: bin/setup-ssl tu@email.com}"
COMPOSE="docker compose -f docker-compose.prod.yml"

echo "→ Asegurando que el puerto 80 esté libre..."
$COMPOSE stop nginx 2>/dev/null || true

echo "→ Creando volumen de certificados..."
docker volume create hive_certbot_certs 2>/dev/null || true

echo "→ Obteniendo certificado para $DOMAIN..."
docker run --rm \
  -p 80:80 \
  -v hive_certbot_certs:/etc/letsencrypt \
  certbot/certbot certonly \
  --standalone \
  --non-interactive \
  --agree-tos \
  --email "$EMAIL" \
  -d "$DOMAIN"

echo "→ Iniciando stack completo..."
$COMPOSE up -d

echo ""
echo "✓ SSL configurado. App disponible en: https://$DOMAIN/hive"
